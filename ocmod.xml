<?xml version="1.0" encoding="utf-8"?>
<modification>
    <name>Iskra Account</name>
    <code>iskra_account</code>
    <version>1.1.0</version>
    <author>Iskra Team</author>
    <link>https://github.com/iskra-ecommerce/iskra_account</link>
    <description>Modern registration form with language preference for OpenCart 4</description>
    
    <!-- Патч 1: Header language flags - замена картинок на текстовые коды -->
    <file path="catalog/view/template/common/language.twig">
        <operation>
            <search><![CDATA[<img src="{{ image }}" alt="{{ name }}" title="{{ name }}">]]></search>
            <add position="replace"><![CDATA[<span class="iskra-flag">{{ code|slice(0,2)|upper }}</span>]]></add>
        </operation>
        <operation>
            <search><![CDATA[<img src="{{ language.image }}" alt="{{ language.name }}" title="{{ language.name }}"/> {{ language.name }}]]></search>
            <add position="replace"><![CDATA[<span class="iskra-flag">{{ language.code|slice(0,2)|upper }}</span> {{ language.name }}]]></add>
        </operation>
    </file>
    
    <!-- Патч 2: PHP 8.4 warning fix -->
    <file path="catalog/controller/startup/extension.php">
        <operation>
            <search><![CDATA[$extension = str_replace(['_', '/'], ['', '\\'], ucwords($result['extension'], '_/'));]]></search>
            <add position="replace"><![CDATA[$extensionName = $result['extension'] ?? '';
            $extension = str_replace(['_', '/'], ['', '\\'], ucwords($extensionName, '_/'));]]></add>
        </operation>
    </file>
</modification>
