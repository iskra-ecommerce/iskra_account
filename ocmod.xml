<?xml version="1.0" encoding="utf-8"?>
<modification>
    <name>Iskra Account</name>
    <code>iskra_account</code>
    <version>2.4.0</version>
    <author>Iskra Team</author>
    <link>https://github.com/iskra-ecommerce/iskra_account</link>
    <description>Современная форма регистрации с выбором страны, языка, маской телефона, доп. валютами и языками для OpenCart 4.</description>

    <file path="catalog/view/template/account/register.twig">
        <operation><search><![CDATA[{{ header }}]]></search><add position="after"><![CDATA[
<link href="extension/iskra_account/resource/css/account.css" rel="stylesheet" type="text/css"/>
<script src="extension/iskra_account/resource/js/account.js" type="text/javascript"></script>
<script src="extension/iskra_account/resource/js/password-strength.js" type="text/javascript"></script>
<script src="extension/iskra_account/resource/js/phone-mask.js" type="text/javascript"></script>
]]></add></operation>
        <operation><search><![CDATA[<input type="tel" name="telephone" value="" placeholder="{{ entry_telephone }}" id="input-telephone" class="form-control"/>]]></search><add position="replace"><![CDATA[{% if iskra_phone_mask %}
                <input type="tel" name="telephone" value="" placeholder="{{ iskra_phone_placeholder }}" id="input-telephone" class="form-control iskra-input--phone" autocomplete="tel" data-oc-mask="phone"/>
{% else %}
                <input type="tel" name="telephone" value="" placeholder="{{ entry_telephone }}" id="input-telephone" class="form-control"/>
{% endif %}]]></add></operation>
        <operation><search><![CDATA[<input type="password" name="password" value="" placeholder="{{ entry_password }}" id="input-password" class="form-control"/>]]></search><add position="replace"><![CDATA[<input type="password" name="password" value="" placeholder="{{ entry_password }}" id="input-password" class="form-control" minlength="{{ iskra_password_min_length }}"{% if iskra_password_strength %} data-oc-toggle="password-strength"{% endif %}/>
{% if iskra_password_strength %}
              <div class="iskra-password-strength" id="password-strength">
                <div class="iskra-password-strength__bar">
                  <div class="iskra-password-strength__fill" style="width: 0%"></div>
                </div>
                <span class="iskra-password-strength__label">{{ text_password_strength }}</span>
              </div>
{% endif %}]]></add></operation>
        <operation><search><![CDATA[<input type="email" name="email" value="" placeholder="{{ entry_email }}" id="input-email" class="form-control"/>]]></search><add position="replace"><![CDATA[<input type="email" name="email" value="" placeholder="{{ entry_email }}" id="input-email" class="form-control" data-oc-url="{{ iskra_check_email_url }}"/>]]></add></operation>
    </file>

    <file path="catalog/view/template/common/header.twig">
        <operation><search><![CDATA[            <li class="list-inline-item">{{ language }}</li>]]></search><add position="replace"><![CDATA[            {% if language %}<li class="list-inline-item">{{ language }}</li>{% endif %}]]></add></operation>
        <operation><search><![CDATA[            <li class="list-inline-item me-3">{{ currency }}</li>]]></search><add position="replace"><![CDATA[            {% if currency %}<li class="list-inline-item me-3">{{ currency }}</li>{% endif %}]]></add></operation>
    </file>

    <file path="catalog/view/template/common/language.twig">
        <operation><search><![CDATA[<img src="{{ image }}" alt="{{ name }}" title="{{ name }}"> <span class="d-none d-md-inline">{{ text_language }}</span>]]></search><add position="replace"><![CDATA[<span class="iskra-lang-code">{{ code|split('-')|first|upper }}</span> <span class="d-none d-md-inline">{{ text_language }}</span>]]></add></operation>
        <operation><search><![CDATA[<img src="{{ language.image }}" alt="{{ language.name }}" title="{{ language.name }}"/> {{ language.name }}]]></search><add position="replace"><![CDATA[<span class="iskra-lang-code">{{ language.code|split('-')|first|upper }}</span> {{ language.name }}]]></add></operation>
    </file>

    <file path="catalog/view/template/common/currency.twig">
        <operation><search trim="true"><![CDATA[{% if symbol_left %}<strong>{{ symbol_left }}</strong>{% elseif symbol_right %}<strong>{{ symbol_right }}</strong>{% endif %} <span class="d-none d-md-inline">{{ text_currency }}</span>]]></search><add position="replace"><![CDATA[<span class="iskra-lang-code">{{ code }}</span> <span class="d-none d-md-inline">{{ text_currency }}</span>]]></add></operation>
        <operation><search trim="true"><![CDATA[{{ currency.symbol_left }} {{ currency.title }}]]></search><add position="replace"><![CDATA[<span class="iskra-lang-code">{{ currency.code }}</span> {{ currency.title }}]]></add></operation>
        <operation><search trim="true"><![CDATA[{{ currency.symbol_right }} {{ currency.title }}]]></search><add position="replace"><![CDATA[<span class="iskra-lang-code">{{ currency.code }}</span> {{ currency.title }}]]></add></operation>
    </file>
</modification>